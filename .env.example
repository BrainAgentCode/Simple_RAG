# =============================================================================
# 航空航天知识问答 RAG 系统 — 环境配置
# 使用：cp .env.example .env  然后填入真实密钥
# =============================================================================

# ---------- 必填（至少配置一种 LLM）----------
# [1] OpenAI 联网模型
OPENAI_API_KEY=xxxx
OPENAI_BASE_URL=https://xxx.xxx.com/
OPENAI_MODEL=gpt-5.4

# [2] 本地 LLaMA 3.3-70B-Instruct-Turbo（OpenAI 兼容 API，如 vLLM / Ollama）
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
LOCAL_LLM_API_KEY=not-needed

# 默认 LLM：openai | local（交互启动时也可再选）
LLM_PROVIDER=openai

# ---------- 数据与索引 ----------
RAG_DATA_PATH=./data/nasa
RAG_INDEX_PATH=./vector_index
SOURCE_MODE=aerospace

# ---------- DeepL（中文问句检索翻译兜底，建议配置）----------
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
DEEPL_API_MODE=deepl

# ---------- 嵌入模型与检索 ----------
EMBEDDING_MODEL=microsoft/harrier-oss-v1-270m
RAG_TOP_K=3
TRANSLATE_QUERY_FOR_BM25=true
TRANSLATE_QUERY_FOR_VECTOR=true

# ---------- LLM 生成参数 ----------
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ---------- 加速：嵌入 GPU + FAISS GPU + LLM 多线程 ----------
EMBEDDING_DEVICE=cuda
FAISS_USE_GPU=true
FAISS_GPU_ID=0
EMBEDDING_BATCH_SIZE=64
# GPU 编码 micro-batch（0=自动：CUDA 下默认 8；长文档务必保持小值）
EMBEDDING_ENCODE_BATCH_SIZE=8
LLM_MAX_WORKERS=6

# 无 GPU 时：
# EMBEDDING_DEVICE=cpu
# FAISS_USE_GPU=false
# EMBEDDING_BATCH_SIZE=64

# ---------- RAGAS 评估 ----------
# judge 用 API；embedding 默认 local，与 EMBEDDING_MODEL 一致
RAGAS_LLM_MODEL=gpt-4o-mini
RAGAS_EMBEDDING_BACKEND=local
RAGAS_EMBEDDING_MODEL=
RAGAS_EMBEDDING_DEVICE=
# 若改用 OpenAI embedding：RAGAS_EMBEDDING_BACKEND=openai
# RAGAS_EMBEDDING_MODEL=text-embedding-3-small

# ---------- NASA 爬虫 ----------
# CHROME_BIN=/usr/bin/chromium

# ---------- 本地 LLaMA 部署示例（vLLM）----------
# python -m vllm.entrypoints.openai.api_server \
#   --model meta-llama/Llama-3.3-70B-Instruct-Turbo \
#   --port 8000
