# cp .env.example .env  然后填入真实密钥

# ---------- LLM（必填）----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 本地 LLM（vLLM / Ollama 等 OpenAI 兼容 API）
# LOCAL_LLM_BASE_URL=http://localhost:8000/v1
# LOCAL_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# LLM_PROVIDER=local

# ---------- 数据与向量索引 ----------
RAG_DATA_PATH=./data/nasa
RAG_INDEX_PATH=./vector_index

# ---------- 嵌入模型（检索 + RAGAS 默认共用）----------
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# Cross-Encoder 精排（RRF 之后；首次检索时加载）
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_MODEL=zeroentropy/zerank-2-reranker  # 4B，需大显存 + sentence-transformers>=3
# RERANKER_DEVICE=cuda

# ---------- RAGAS 评测（可选）----------
# RAGAS_LLM_MODEL=gpt-4o-mini
# RAGAS_MAX_WORKERS=2
# RAGAS_TIMEOUT=3600
# RAGAS_LLM_TIMEOUT=3600
# RAGAS_EMBEDDING_BACKEND=local

# ---------- 可选 ----------
# DEEPL_API_KEY=
